@model dynamic
@using Microsoft.Extensions.Options
@inject IServiceProvider ServiceProvider
@{
    Layout = null;

    string extensions = Model.Extensions;
    bool allowNewRootFolders = Model.AllowNewRootFolders;

    // Resolve MediaOptions dynamically (internal type in OrchardCore.Media)
    long maxUploadChunkSize = 0;
    try
    {
        var mediaOptionsType = AppDomain.CurrentDomain.GetAssemblies()
            .Select(a => a.GetType("OrchardCore.Media.MediaOptions"))
            .FirstOrDefault(t => t != null);
        if (mediaOptionsType != null)
        {
            var iOptionsType = typeof(IOptions<>).MakeGenericType(mediaOptionsType);
            var optionsWrapper = ServiceProvider.GetService(iOptionsType);
            if (optionsWrapper != null)
            {
                var valueProp = iOptionsType.GetProperty("Value");
                var optionsValue = valueProp?.GetValue(optionsWrapper);
                var chunkProp = mediaOptionsType.GetProperty("MaxUploadChunkSize");
                maxUploadChunkSize = (long)(chunkProp?.GetValue(optionsValue) ?? 0L);
            }
        }
    }
    catch
    {
        /* fall back to default */
    }
}

<div id="mediaApp" class="media-app-redesign" style="display:none;" v-on:dragover="handleScrollWhileDrag($event)">
    <div id="customdropzone">
        <div class="d-flex flex-column align-items-center justify-content-center h-100 gap-2">
            <i class="fa-solid fa-cloud-arrow-up fa-3x"></i>
            <h4 class="mb-0">@T["Drop your media here"]</h4>
            <p class="mb-0 opacity-75">@T["Your files will be uploaded to the current folder when you drop them here"]</p>
        </div>
    </div>

    <div class="alert alert-warning alert-dismissible message-warning mb-0 rounded-0" v-if="errors.length > 0">
        <ul class="mb-0 ps-3">
            <li v-for="e in errors">
                <span>{{e}}</span>
            </li>
        </ul>
    </div>

    <div id="mediaContainer" class="align-items-stretch">
        @* ── Folder Sidebar ── *@
        <div id="navigationApp" class="media-container-navigation m-0 p-0" v-cloak>
            <ol id="folder-tree" class="py-2">
                <folder :model="root" ref="rootFolder" :selected-in-media-app="selectedFolder" :level="1">
                </folder>
            </ol>
        </div>

        @* ── Main Content ── *@
        <div id="mediaContainerMain" v-cloak>
            <div class="media-container-top-bar">
                @* ── Toolbar ── *@
                <nav class="nav action-bar py-2 px-3 d-flex flex-wrap align-items-center gap-2 border-bottom">
                    @* Selection Actions *@
                    <div class="d-flex align-items-center gap-1 me-auto">
                        <a href="javascript:;" class="btn btn-outline-secondary btn-sm" v-on:click="selectAll">
                            @T["Select All"]
                        </a>
                        <a href="javascript:;" class="btn btn-outline-secondary btn-sm" v-on:click="unSelectAll" :class="{disabled: selectedMedias.length < 1 }">
                            @T["Select None"]
                        </a>
                        <a href="javascript:;" class="btn btn-outline-secondary btn-sm" v-on:click="invertSelection">
                            @T["Invert"]
                        </a>

                        <div class="vr mx-1 opacity-25"></div>

                        <a href="javascript:;" class="btn btn-outline-danger btn-sm" v-on:click="deleteMediaList" :class="{disabled: selectedMedias.length < 1 }">
                            <i class="fa-solid fa-trash-alt me-1" aria-hidden="true"></i>@T["Delete"]
                            <span class="badge rounded-pill text-bg-danger ms-1" v-show="selectedMedias.length > 0">{{ selectedMedias.length }}</span>
                        </a>
                    </div>

                    @* View Toggle *@
                    <div class="btn-group visibility-buttons" role="group">
                        <button type="button" id="toggle-grid-table-button-grid" class="btn btn-sm btn-outline-secondary" :class="{active: gridView}" v-on:click="gridView = true">
                            <span title="@T["Grid View"]">
                                <i class="fa-solid fa-th-large" aria-hidden="true"></i>
                            </span>
                        </button>
                        <button type="button" id="toggle-grid-table-button-table" class="btn btn-sm btn-outline-secondary" :class="{active: !gridView}" v-on:click="gridView = false">
                            <span title="@T["List View"]">
                                <i class="fa-solid fa-th-list" aria-hidden="true"></i>
                            </span>
                        </button>
                    </div>

                    @* Thumb Size Toggle (grid only) *@
                    <div class="btn-group visibility-buttons" v-show="gridView" role="group">
                        <button type="button" id="toggle-thumbsize-button-small" class="btn btn-sm btn-outline-secondary" :class="{active: smallThumbs}" v-on:click="smallThumbs = true">
                            <span title="@T["Small Thumbs"]">
                                <i class="fa-solid fa-compress" aria-hidden="true"></i>
                            </span>
                        </button>
                        <button type="button" id="toggle-thumbsize-button-large" class="btn btn-sm btn-outline-secondary" :class="{active: !smallThumbs}" v-on:click="smallThumbs = false">
                            <span title="@T["Large Thumbs"]">
                                <i class="fa-solid fa-expand" aria-hidden="true"></i>
                            </span>
                        </button>
                    </div>

                    @* Filter *@
                    <div class="media-filter">
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-transparent border-end-0">
                                <i class="fa-solid fa-search text-muted small"></i>
                            </span>
                            <input type="text" id="media-filter-input" v-model="mediaFilter"
                                   class="form-control border-start-0 ps-0 input-filter"
                                   placeholder="@T["Filter..."]" aria-label="@T["Filter..."]">
                            <button id="clear-media-filter-button" class="btn btn-outline-secondary" type="button"
                                    :disabled="mediaFilter == ''" v-on:click="mediaFilter = ''">
                                <i class="fa-solid fa-times" aria-hidden="true"></i>
                            </button>
                        </div>
                    </div>

                    @* Upload *@
                    <div class="btn-group btn-group-sm">
                        <label for="fileupload" class="btn btn-primary btn-sm fileinput-button upload-button d-flex align-items-center gap-1 mb-0">
                            <input id="fileupload" type="file" name="files" multiple="multiple" accept="@extensions">
                            <i class="fa-solid fa-cloud-arrow-up" aria-hidden="true"></i>
                            @T["Upload"]
                        </label>
                    </div>
                </nav>

                @* ── Breadcrumb ── *@
                <nav id="breadcrumb" class="d-flex align-items-center border-bottom">
                    <div class="breadcrumb-path px-3 py-2 d-flex align-items-center gap-1 small">
                        <i class="fa-solid fa-folder-open text-muted me-1"></i>
                        <span class="breadcrumb-item" :class="{ active: isHome }">
                            <a id="t-mediaLibrary" :href="isHome ? null : '#'" v-on:click="selectRoot">@T["Media Library"]</a>
                        </span>
                        <span v-for="(folder, i) in parents" v-cloak
                              class="breadcrumb-item"
                              :class="{active: parents.length - i == 1}">
                            <a :href="parents.length - i == 1 ? null : '#'" v-on:click="selectedFolder = folder;">{{ folder.name }}</a>
                        </span>
                    </div>
                </nav>
            </div>

            @* ── Media Items ── *@
            <div class="media-container-middle p-3">
                <upload-list></upload-list>

                <media-items-table :sort-by="sortBy" :sort-asc="sortAsc"
                                   :filtered-media-items="itemsInPage"
                                   :selected-medias="selectedMedias"
                                   :thumb-size="thumbSize"
                                   v-if="itemsInPage.length > 0 && !gridView">
                </media-items-table>

                <media-items-grid v-if="gridView"
                                  :filtered-media-items="itemsInPage"
                                  :selected-medias="selectedMedias"
                                  :thumb-size="thumbSize">
                </media-items-grid>

                <div class="text-center text-muted py-4" v-show="mediaItems.length > 0 && filteredMediaItems.length < 1">
                    <i class="fa-solid fa-filter-circle-xmark fa-2x mb-2 d-block"></i>
                    @T["Nothing to show with this filter"]
                </div>
                <div class="text-center text-muted py-5" v-show="mediaItems.length < 1">
                    <i class="fa-regular fa-folder-open fa-3x mb-3 d-block opacity-50"></i>
                    <span class="d-block">@T["This folder is empty"]</span>
                    <small class="text-muted">@T["Upload files or create subfolders to get started"]</small>
                </div>
            </div>

            @* ── Pagination ── *@
            <div v-show="filteredMediaItems.length > 0" class="media-container-footer px-3 py-2 border-top">
                <pager :source-items="filteredMediaItems"> </pager>
            </div>
        </div>
    </div>
</div>

@* Endpoints *@
<input type="hidden" id="getFoldersUrl" value="@Url.Action("GetFolders", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="deleteFolderUrl" value="@Url.Action("DeleteFolder", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="createFolderUrl" value="@Url.Action("CreateFolder", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="getMediaItemsUrl" value="@Url.Action("GetMediaItems", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="deleteMediaUrl" value="@Url.Action("DeleteMedia", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="renameMediaUrl" value="@Url.Action("MoveMedia", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="deleteMediaListUrl" value="@Url.Action("DeleteMediaList", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="moveMediaListUrl" value="@Url.Action("MoveMediaList", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="uploadFiles" value="@Url.Action("Upload", "Admin", new { area = "OrchardCore.Media" })"/>
<input type="hidden" id="allowedExtensions" value="@extensions"/>

@* Settings *@
<input type="hidden" id="allowNewRootFolders" value="@(allowNewRootFolders ? "true" : "false")"/>

@* Chunked file upload settings *@
<input type="hidden" id="maxUploadChunkSize" value="@maxUploadChunkSize"/>

@*Localizable Strings shared*@
<input type="hidden" id="deleteFolder" data-title="@T["Delete media folder"]" data-message="@T["Are you sure you want to delete this folder?"]"/>
<input type="hidden" id="deleteMedia" data-title="@T["Delete media"]" data-message="@T["Are you sure you want to delete these media items?"]"/>
<input type="hidden" id="moveMedia" data-title="@T["Move media"]" data-message="@T["Are you sure you want to move the selected media to this folder?"]" data-ok-text="@T["Yes"]" data-cancel-text="@T["No"]" data-ok-class="btn-success"/>
<input type="hidden" id="sameFolderMessage" value="@T["The media is already on this folder"]"/>
<input type="hidden" id="t-edit-button" value="@T["Edit"]"/>
<input type="hidden" id="t-delete-button" value="@T["Delete"]"/>
<input type="hidden" id="t-view-button" value="@T["View"]"/>

@*Localizable Strings for uploadComponent*@
<input type="hidden" id="t-error" value="@T["This file exceeds the maximum upload size"]"/>

@*Localizable Strings for uploadListcomponent*@
<input type="hidden" id="t-uploads" value="@T["Uploads"]"/>
<input type="hidden" id="t-errors" value="@T["Errors"]"/>
<input type="hidden" id="t-clear-errors" value="@T["Clear Errors"]"/>

@*Localizable Strings for mediaItemsTableComponent*@
<input type="hidden" id="t-image-header" value="@T["Image"]"/>
<input type="hidden" id="t-name-header" value="@T["Name"]"/>
<input type="hidden" id="t-lastModify-header" value="@T["Last modification"]"/>
<input type="hidden" id="t-size-header" value="@T["Size"]"/>
<input type="hidden" id="t-type-header" value="@T["Type"]"/>

@*Localizable Strings for pagerComponent*@
<input type="hidden" id="t-pager-first-button" value="@T["First"]"/>
<input type="hidden" id="t-pager-previous-button" value="@T["Previous"]"/>
<input type="hidden" id="t-pager-next-button" value="@T["Next"]"/>
<input type="hidden" id="t-pager-last-button" value="@T["Last"]"/>
<input type="hidden" id="t-pager-page-size-label" value="@T["Page Size"]"/>
<input type="hidden" id="t-pager-page-label" value="@T["Page:"]"/>
<input type="hidden" id="t-pager-total-label" value="@T["Total items:"]"/>

@* ── Create Folder Modal ── *@
<div class="modal" id="createFolderModal" tabindex="-1" role="dialog" aria-labelledby="createFolderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content rounded-3 shadow">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-semibold" id="createFolderModalLabel">
                    <i class="fa-solid fa-folder-plus text-primary me-2"></i>@T["Create Folder"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div class="mb-3">
                    <label for="create-folder-name" class="form-label fw-medium" id="input-label">@T["Folder name"]</label>
                    <input type="text" id="create-folder-name" class="form-control" placeholder="@T["Enter folder name..."]">
                </div>
                <div id="createFolderModal-errors"></div>
            </div>
            <div class="modal-footer border-top px-4 py-3">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="modalFooterOk">
                    <i class="fa-solid fa-check me-1"></i>@T["Ok"]
                </button>
            </div>
        </div>
    </div>
</div>

@* ── Rename Modal ── *@
<div class="modal" id="renameMediaModal" tabindex="-1" role="dialog" aria-labelledby="renameMediaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content rounded-3 shadow">
            <div class="modal-header border-bottom px-4 py-3">
                <h5 class="modal-title fw-semibold" id="renameMediaModalLabel">
                    <i class="fa-solid fa-pen text-primary me-2"></i>@T["Rename Item"]
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body px-4 py-3">
                <div class="mb-3">
                    <label for="new-item-name" class="form-label fw-medium" id="input-label">@T["New Name"]</label>
                    <input type="text" id="new-item-name" class="form-control" placeholder="@T["Enter new name..."]">
                    <input type="hidden" id="old-item-name" value="">
                </div>
                <div id="renameMediaModal-errors"></div>
            </div>
            <div class="modal-footer border-top px-4 py-3">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@T["Cancel"]</button>
                <button type="button" class="btn btn-primary" id="renameMediaModalFooterOk">
                    <i class="fa-solid fa-check me-1"></i>@T["Ok"]
                </button>
            </div>
        </div>
    </div>
</div>