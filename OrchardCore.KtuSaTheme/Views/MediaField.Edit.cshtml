@model dynamic
@using System.Text.Json.Nodes
@using OrchardCore.ContentManagement.Metadata.Models
@using OrchardCore.ContentManagement.Metadata.Settings
@using OrchardCore.Mvc.Utilities
@using OrchardCore
@{
    var partFieldDef = (ContentPartFieldDefinition)Model.PartFieldDefinition;
    var mediaSettings = partFieldDef.Settings["MediaFieldSettings"]?.AsObject();

    var isRequired = mediaSettings?["Required"]?.GetValue<bool>() ?? false;
    var hint = mediaSettings?["Hint"]?.GetValue<string>() ?? "";
    var isMultiple = mediaSettings?["Multiple"]?.GetValue<bool>() ?? false;
    var allowMediaText = mediaSettings?["AllowMediaText"]?.GetValue<bool>() ?? false;
    var allowAnchors = mediaSettings?["AllowAnchors"]?.GetValue<bool>() ?? false;

    var prefix = ViewData.TemplateInfo.HtmlFieldPrefix ?? "";

    string SanitizeId(string name)
    {
        return name.Replace(".", "_").Replace("[", "_").Replace("]", "_");
    }

    var containerId = SanitizeId(prefix);
    var pathsId = SanitizeId(string.IsNullOrEmpty(prefix) ? "Paths" : prefix + ".Paths");
    var pathsName = string.IsNullOrEmpty(prefix) ? "Paths" : prefix + ".Paths";
    var wrapperId = pathsId + "_FieldWrapper";

    var allowedExtensions = (string[])Model.AllowedExtensions;
}
<style asp-name="media" at="Head"></style>

<div class="@Orchard.GetFieldWrapperClasses(partFieldDef)" id="@wrapperId">
    <label for="@pathsId" class="@Orchard.GetLabelClasses(isRequired)">@partFieldDef.DisplayName()</label>
    <div class="@Orchard.GetEndClasses()" id="@containerId" data-for="@pathsId">
        @if (!string.IsNullOrWhiteSpace(hint))
        {
            <div class="hint mt-lg-2">@hint</div>
        }

        <input type="hidden" name="@pathsName" id="@pathsId" class="paths" :value="paths" data-init="@Model.Paths"/>

        <div class="media-field-toolbar mb-2 d-flex align-items-center gap-2" v-cloak>
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-outline-secondary btn-sm" :disabled="mediaItems.length < 1" v-on:click="smallThumbs = !smallThumbs">
                    <span v-show="!smallThumbs" title="@T["Small Thumbs"]">
                        <i class="fa-solid fa-compress-alt" aria-hidden="true"></i>
                    </span>
                    <span v-show="smallThumbs" title="@T["Large Thumbs"]">
                        <i class="fa-solid fa-expand-alt" aria-hidden="true"></i>
                    </span>
                </button>
                <a href="javascript:;" v-show="canAddMedia" v-on:click="showModal" class="btn btn-primary btn-sm">
                    <i class="fa-solid fa-plus me-1" aria-hidden="true"></i>@T["Browse"]
                </a>
                <a href="javascript:;" v-show="allowMediaText" v-on:click="showMediaTextModal" class="btn btn-outline-secondary btn-sm" v-bind:class="{ disabled : !selectedMedia }">
                    <i class="far fa-comment" aria-hidden="true"></i>
                </a>
                <a href="javascript:;" v-show="allowAnchors" v-on:click="showAnchorModal" class="btn btn-outline-secondary btn-sm" v-bind:class="{ disabled : !selectedMedia }">
                    <i class="fa-solid fa-crosshairs" aria-hidden="true"></i>
                </a>
                <a href="javascript:;" v-on:click="removeSelected" class="btn btn-outline-danger btn-sm" v-bind:class="{ disabled : !selectedMedia }">
                    <i class="fa-solid fa-trash-alt" aria-hidden="true"></i>
                </a>
            </div>
            <label class="selected-media-name form-label mb-0 ms-2">
                <code class="text-end small" v-if="selectedMedia">@T["{{{{ selectedMedia.name }}}}{{{{ selectedMedia.mediaText === '' ? '' : ', ' + selectedMedia.mediaText }}}} ({{{{ isNaN(fileSize)? 0 : fileSize }}}} KB)"]</code>
            </label>
        </div>

        <media-field-thumbs-container :media-items="mediaItems" :thumb-size="thumbSize" :selected-media="selectedMedia" :id-prefix="idPrefix" :allow-anchors="allowAnchors"></media-field-thumbs-container>

        <partial name="/Areas/OrchardCore.Media/Views/Shared/MediaFieldEditMediaTextModal.cshtml"/>
        <partial name="/Areas/OrchardCore.Media/Views/Shared/MediaFieldEditAnchorModal.cshtml"/>

        <span class="field-validation-valid" data-valmsg-for="@pathsName" data-valmsg-replace="true"></span>

    </div>

    <div class="modal" id="@containerId-ModalBody">
        <div class="modal-dialog modal-xl media-modal" role="document">
            <div class="modal-content shadow-lg border-0 rounded-3 overflow-hidden">
                <div class="modal-header border-bottom px-4 py-3">
                    <h5 class="modal-title fw-semibold d-flex align-items-center gap-2">
                        <i class="fa-regular fa-images text-primary"></i>
                        @T["Select Media"]
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body"></div>
                <div class="modal-footer border-top px-4 py-3 d-flex justify-content-end gap-2">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">
                        @T["Cancel"]
                    </button>
                    <button type="button" class="btn btn-primary px-4 mediaFieldSelectButton">
                        <i class="fa-solid fa-check me-1"></i>@T["OK"]
                    </button>
                </div>
            </div>
        </div>
    </div>
    <partial name="/Areas/OrchardCore.Media/Views/Shared/MediaFieldEditLocalization.cshtml"/>
</div>

<script asp-name="media" at="Foot"></script>
<script at="Foot" asp-name="MediaFieldAppInitializer" depends-on="media">
    initializeMediaApplication(false, '@Url.Action("MediaApplication", "Admin", new { area = "OrchardCore.Media", extensions = string.Join(',', allowedExtensions) })', '@Context.Request.PathBase.ToString()');
</script>

<script at="Foot">
    initializeMediaField(
        document.getElementById('@containerId'),
        document.getElementById('@containerId-ModalBody'),
        '@Url.Action("GetMediaItem", "Admin", new { area = "OrchardCore.Media" })',
        @(isMultiple ? "true" : "false"),
        @(allowMediaText ? "true" : "false"),
        @(allowAnchors ? "true" : "false"),
        '@string.Join(',', allowedExtensions)');
</script>