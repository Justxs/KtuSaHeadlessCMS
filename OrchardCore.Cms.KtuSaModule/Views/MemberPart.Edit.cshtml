@model OrchardCore.Cms.KtuSaModule.ViewModels.MemberPartViewModel

<!-- TODO add localization -->


<fieldset class="form-group" asp-validation-class-for="Name" style="margin-bottom: 20px;">
    <label asp-for="Name">
        Member Name
    </label>

    <input asp-for="Name"
           class="form-control"
           value="@Model.Name"
           required />
</fieldset>

<fieldset class="form-group" asp-validation-class-for="SaUnit">
    <label class="form-label" asp-for="SaUnit">
        SA Unit
    </label>

    <select 
        asp-for="SaUnit" 
        asp-items="Html.GetEnumSelectList<OrchardCore.Cms.KtuSaModule.Models.Enums.SaUnit>()"
        class="form-control"
        >
            @Model.SaUnit
    </select>
</fieldset>