@model PdfUploadFieldViewModel

<fieldset class="form-group" asp-validation-class-for="UploadedFile" style="margin-bottom: 20px; display: flex; gap: 20px">
    <div>
        <label asp-for="UploadedFile" class="control-label">
            @Model.Label
        </label>

        <input asp-for="UploadedFile"
               type="file" 
               class="form-control"
               accept="application/pdf" />
    </div>

    @if (Model.FileId is not null)
    {
        <p>@Model.FileId</p>
    }
</fieldset>